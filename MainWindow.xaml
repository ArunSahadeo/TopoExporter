<Window x:Class="TopoExporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:TopoExporter"
        Title="TopoExporter" Height="700" Width="1200"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Dark mode template triggered by tag -->
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="260"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════ LEFT PANE ═══════════════════════ -->
        <Border Grid.Column="0" x:Name="LeftPanel"
                Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True" Margin="0">

                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="#0078D4" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="TopoExporter" FontSize="18" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock x:Name="SubtitleText"
                                   Text="Select countries to export"
                                   FontSize="11" Foreground="#B0D8FF" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Search Box -->
                <Border DockPanel.Dock="Top" Padding="10,8" Background="#F8F9FA"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="SearchBox"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Search countries..."
                                 Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="✕" Width="30" Padding="6,0,6,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="ClearSearch_Click" ToolTip="Clear search"/>
                    </Grid>
                </Border>

                <!-- Add All / Clear All -->
                <Border DockPanel.Dock="Top" Padding="10,6" Background="#F8F9FA"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="✓ Add All"
                                Style="{StaticResource SuccessButton}"
                                Command="{Binding AddAllCommand}"/>
                        <Button Grid.Column="2" Content="✕ Clear All"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ClearAllCommand}"/>
                    </Grid>
                </Border>

                <!-- Country List -->
                <Border DockPanel.Dock="Top" Padding="0" x:Name="ListContainer"
                        MinHeight="200">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <ItemsControl x:Name="CountryList"
                                      ItemsSource="{Binding PagedCountries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="ItemBorder" Padding="12,7"
                                            BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Style="{StaticResource ModernCheckBox}">
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       TextTrimming="CharacterEllipsis" MouseEnter="CountryName_MouseEnter" MouseLeave="CountryName_MouseLeave">
                                            </TextBlock>
                                        </CheckBox>
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="Border.MouseEnter"/>
                                        </Border.Triggers>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#EBF4FF"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Pagination -->
                <Border DockPanel.Dock="Top" Padding="10,6"
                        BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                        Background="#F8F9FA">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="◀ Prev"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding PrevPageCommand}"/>
                        <TextBlock Grid.Column="1" x:Name="PageInfoText"
                                   Text="{Binding PageInfo}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontSize="12" Foreground="#555" Margin="8,0"/>
                        <Button Grid.Column="2" Content="Next ▶"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding NextPageCommand}"/>
                    </Grid>
                </Border>

                <!-- Action Buttons -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10,8">
                    <Button Content="⬇ Export TopoJSON"
                            Style="{StaticResource SuccessButton}"
                            Command="{Binding ExportCommand}"
                            Height="34" FontSize="13" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Save Preset"
                                Style="{StaticResource ModernButton}"
                                Command="{Binding SavePresetCommand}" Height="30"/>
                        <Button Grid.Column="2" Content="📂 Load Preset"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding LoadPresetCommand}" Height="30"/>
                    </Grid>
                    <Button x:Name="DarkModeBtn" Content="🌙 Toggle Dark Mode"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ToggleDarkModeCommand}" Height="30"/>
                </StackPanel>

                <!-- Status -->
                <Border DockPanel.Dock="Bottom" Padding="10,5"
                        Background="#EFEFEF" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="StatusText"
                               Text="{Binding StatusText}"
                               FontSize="11" Foreground="#666"
                               TextTrimming="CharacterEllipsis"/>
                </Border>

                <!-- Loading Overlay -->
                <Border DockPanel.Dock="Bottom" x:Name="LoadingBar"
                        Background="#FFF3CD" Padding="10,5"
                        Visibility="{Binding IsLoading, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳ " FontSize="12"/>
                        <TextBlock Text="Working..." FontSize="11" Foreground="#856404"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="#E0E0E0" Cursor="SizeWE"/>

        <!-- ═══════════════════════ RIGHT PANE (MAP) ═══════════════════════ -->
        <Grid Grid.Column="2">
            <wv2:WebView2 x:Name="MapWebView"
                          Source="about:blank"/>
            <Border x:Name="MapLoadingOverlay"
                    Background="#E8F0F7"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🗺️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Loading map…" FontSize="14" Foreground="#555"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock x:Name="MapStatusText" Text="Initialising…"
                               FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Popup x:Name="CountryPopup" Placement="Mouse" AllowsTransparency="True" StaysOpen="False" PopupAnimation="Fade" IsOpen="False">
            <Border Background="#FCFCFE" BorderBrush="#A0C0E0" BorderThickness="1" CornerRadius="4" Padding="10" MaxWidth="260">
                <StackPanel DataContext="{Binding SelectedCountryForPopup}" Width="220">
                    <TextBlock FontWeight="SemiBold" FontSize="14" Text="{Binding Name}"/>
                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#555" Text="{Binding Code, StringFormat='ISO code: {0}'}"/>
                    <Button Margin="0,12,0,4" Padding="14,6" HorizontalAlignment="Left" Content="Zoom to country on map" Click="ZoomToCountryClick" CommandParameter="{Binding Code}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
